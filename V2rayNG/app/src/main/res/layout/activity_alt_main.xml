<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060D1A"
    tools:context=".ui.AltMainActivity">

    <View
        android:layout_width="700dp"
        android:layout_height="700dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-250dp"
        android:alpha="0.9"
        android:background="@drawable/glow_blue_500" />

    <View
        android:layout_width="520dp"
        android:layout_height="520dp"
        android:layout_gravity="center"
        android:layout_marginTop="-80dp"
        android:alpha="1"
        android:background="@drawable/glow_blue_center" />

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-120dp"
        android:layout_marginBottom="-100dp"
        android:alpha="0.35"
        android:background="@drawable/glow_blue_500" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/header_icon"
                android:layout_width="40dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="@string/app_name"
                app:tint="#123B73" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALT VPN"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/header_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="приватный"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A2A45"
            android:alpha="0.5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="12dp"
            android:paddingTop="8dp"
            android:gravity="top">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="280dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp">

                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_dark_circle" />

                <View
                    android:layout_width="180dp"
                    android:layout_height="180dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_border"
                    android:alpha="0.8" />

                <View
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_fab_glow"
                    android:backgroundTint="#123B73"
                    android:alpha="0.35" />

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fab"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play_24dp"
                    android:backgroundTint="#123B73"
                    app:fabCustomSize="36dp"
                    app:maxImageSize="16dp"
                    app:elevation="18dp"
                    app:borderWidth="0dp" />
            </FrameLayout>

            <!-- Luna VPN Card - ПОДНЯТ ВВЕРХ в 1.3 раза: 10dp -> 7dp -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="0dp"
                app:cardBackgroundColor="#16213A"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#123B73">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/circle_dot"
                            android:backgroundTint="#123B73" />

                        <TextView
                            android:id="@+id/server_name_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="8dp"
                            android:text="Luna VPN — Netherlands"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="214ms"
                            android:textSize="12sp"
                            android:textColor="#7A8BB0" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/server_desc_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginStart="16dp"
                        android:alpha="0.7"
                        android:text="VLESS • защищённый туннель"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:background="@drawable/circle_dot"
                            android:backgroundTint="#123B73"
                            android:alpha="0.2" />

                        <TextView
                            android:id="@+id/server_country_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="-14dp"
                            android:text="Netherlands Server"
                            android:textColor="#A0B0D0"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="0dp"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_chart"
                        app:tint="#6A7DA0" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="СТАТИСТИКА"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:textColor="#6A7DA0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="#16213A"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#1F335A">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="start|center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingVertical="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↓ СКАЧАТЬ"
                                android:gravity="start"
                                android:textAlignment="viewStart"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="#6A7DA0" />

                            <TextView
                                android:id="@+id/download_speed_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="start"
                                android:textAlignment="viewStart"
                                android:layout_marginTop="0dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mb/s"
                                android:textColor="#6A7DA0"
                                android:gravity="start"
                                android:textAlignment="viewStart"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="#16213A"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#1F335A">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="start|center_vertical"
                            android:orientation="vertical"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingVertical="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑ ЗАГРУЗИТЬ"
                                android:gravity="start"
                                android:textAlignment="viewStart"
                                android:textSize="8sp"
                                android:textStyle="bold"
                                android:textColor="#6A7DA0" />

                            <TextView
                                android:id="@+id/upload_speed_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0.0"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:gravity="start"
                                android:textAlignment="viewStart"
                                android:layout_marginTop="0dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mb/s"
                                android:textColor="#6A7DA0"
                                android:gravity="start"
                                android:textAlignment="viewStart"
                                android:textSize="8sp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/view_all_servers_btn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:minHeight="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_marginTop="12dp"
                android:text="Смотреть все серверы"
                android:textSize="11sp"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_arrow_right"
                app:iconGravity="end"
                app:iconSize="16dp"
                app:iconPadding="4dp"
                android:backgroundTint="#1C2A45"
                android:textColor="#FFFFFF"
                android:elevation="0dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/search_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="45dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginEnd="3dp"
                    android:layout_marginTop="0dp"
                    android:text="Начать искать"
                    android:textSize="10sp"
                    app:cornerRadius="11dp"
                    android:backgroundTint="#19243C"
                    android:textColor="#A0B0D0"
                    app:icon="@drawable/ic_search"
                    app:iconSize="14dp"
                    app:iconPadding="3dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/edit_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="45dp"
                    android:minHeight="0dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:layout_marginStart="3dp"
                    android:layout_marginTop="0dp"
                    android:text="Редактировать"
                    android:textSize="10sp"
                    app:cornerRadius="11dp"
                    android:backgroundTint="#19243C"
                    android:textColor="#A0B0D0"
                    app:icon="@drawable/ic_edit"
                    app:iconSize="14dp"
                    app:iconPadding="3dp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp" />

        </LinearLayout>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#131D32"
            app:menu="@menu/menu_alt_bottom_nav"
            app:itemTextColor="@color/bottom_nav_color"
            app:itemIconTint="@color/bottom_nav_color"
            app:elevation="0dp" />
    </LinearLayout>
</FrameLayout>
