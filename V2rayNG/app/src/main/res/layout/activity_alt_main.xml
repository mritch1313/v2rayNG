<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient"
    tools:context=".ui.AltMainActivity">

    <!-- Header как на скрине -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#1D2B4A"
            app:strokeWidth="1dp"
            app:strokeColor="#263759"
            app:cardElevation="0dp">

            <ImageView
                android:id="@+id/header_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_lock"
                app:tint="#FFC440" />
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/header_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ALT VPN"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#EAF0FF"
                android:letterSpacing="0.02" />

            <TextView
                android:id="@+id/header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Core Service"
                android:textSize="12sp"
                android:textColor="#7C8AA6"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#1A2742"
            app:strokeColor="#222F4D"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_sun"
                app:tint="#FFC440" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            app:cardCornerRadius="18dp"
            app:cardBackgroundColor="#1A2742"
            app:strokeColor="#222F4D"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_right"
                android:rotation="315"
                app:tint="#8BA0C7" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Соединение не установлено"
        android:textSize="15sp"
        android:textColor="#7E8EAF"
        android:gravity="center"
        android:layout_marginTop="18dp"
        android:alpha="0.9" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="18dp"
            android:paddingBottom="16dp">

            <!-- ЦЕНТРАЛЬНАЯ КНОПКА КАК НА СКРИНЕ -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="340dp"
                android:layout_gravity="center">

                <!-- Большой темный круг -->
                <View
                    android:layout_width="268dp"
                    android:layout_height="268dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_outer_gradient" />

                <!-- Синее свечение под кнопкой -->
                <View
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_gravity="center"
                    android:background="@drawable/circle_blue_glow" />

                <!-- Синяя кнопка - твой FAB -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/fab"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center"
                    app:cardCornerRadius="48dp"
                    app:cardBackgroundColor="#2F57FF"
                    app:cardElevation="16dp"
                    app:strokeWidth="0dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <View
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            android:background="@drawable/bg_orange_play" />

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_play_white"
                            android:layout_marginStart="3dp" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>
            </FrameLayout>

            <!-- Карточка сервера - СТЕКЛО -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:cardCornerRadius="22dp"
                app:cardBackgroundColor="#151E32"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#1E2F52">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/server_name_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Luna VPN — Netherlands"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#E9EEFF" />

                    <TextView
                        android:id="@+id/server_desc_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VLESS • защищённый туннель"
                        android:textSize="12sp"
                        android:textColor="#7B89A6"
                        android:layout_marginTop="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="14dp">

                        <View
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:background="@drawable/dot_blue" />

                        <TextView
                            android:id="@+id/server_country_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Netherlands Server"
                            android:textSize="13sp"
                            android:textColor="#C2CBE0"
                            android:layout_marginStart="10dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="214ms"
                            android:textSize="13sp"
                            android:textColor="#7B89A6" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Статистика -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:paddingStart="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊  СТАТИСТИКА"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#7C8AA6"
                    android:letterSpacing="0.08" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- Скачать -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#151E32"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1D2E52"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↓ СКАЧАТЬ"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#6E7E9E"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/download_speed_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#E9EEFF"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mb/s"
                            android:textSize="11sp"
                            android:textColor="#6E7E9E"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Загрузить -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="7dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#151E32"
                    app:strokeWidth="1dp"
                    app:strokeColor="#1D2E52"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="↑ ЗАГРУЗИТЬ"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#6E7E9E"
                            android:letterSpacing="0.06" />

                        <TextView
                            android:id="@+id/upload_speed_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#E9EEFF"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Mb/s"
                            android:textSize="11sp"
                            android:textColor="#6E7E9E"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Смотреть все серверы -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="18dp"
                app:cardBackgroundColor="#151E32"
                app:strokeWidth="1dp"
                app:strokeColor="#1E2F52"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingHorizontal="18dp">

                    <View
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:background="@drawable/dot_blue" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Смотреть все серверы"
                        android:textSize="14sp"
                        android:textColor="#D5DCED"
                        android:layout_marginStart="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="22sp"
                        android:textColor="#5A6B8E" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <!-- Для клика -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/view_all_servers_btn"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="-56dp"
                app:cornerRadius="18dp"
                android:backgroundTint="#00000000"
                android:text=""
                app:elevation="0dp"
                android:stateListAnimator="@null" />

            <!-- Твои 2 мини кнопки - теперь компактные стеклянные -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/search_btn"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:text="Начать искать"
                    android:textSize="11sp"
                    app:icon="@drawable/ic_search"
                    app:iconSize="16dp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#1A2339"
                    android:textColor="#C2CBE0"
                    app:strokeColor="#1E2F52"
                    app:strokeWidth="1dp"
                    app:elevation="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/edit_btn"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:text="Редактировать"
                    android:textSize="11sp"
                    app:icon="@drawable/ic_edit"
                    app:iconSize="16dp"
                    app:cornerRadius="12dp"
                    android:backgroundTint="#1A2339"
                    android:textColor="#C2CBE0"
                    app:strokeColor="#1E2F52"
                    app:strokeWidth="1dp"
                    app:elevation="0dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0F1A30"
        app:menu="@menu/menu_alt_bottom_nav"
        app:itemIconTint="@color/bottom_nav_color"
        app:itemTextColor="@color/bottom_nav_color"
        app:elevation="0dp" />
</LinearLayout>
