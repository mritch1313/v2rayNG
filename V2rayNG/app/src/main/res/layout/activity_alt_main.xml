<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08101F"
    tools:context=".ui.AltMainActivity">

    <!-- ============ СЛОЙ СВЕЧЕНИЙ - LED ЭФФЕКТ ============ -->
    <View
        android:layout_width="700dp"
        android:layout_height="700dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="-250dp"
        android:alpha="0.9"
        android:background="@drawable/glow_blue_500" />

    <View
        android:layout_width="520dp"
        android:layout_height="520dp"
        android:layout_gravity="center"
        android:layout_marginTop="-80dp"
        android:alpha="1"
        android:background="@drawable/glow_blue_center" />

    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-120dp"
        android:layout_marginBottom="-100dp"
        android:alpha="0.35"
        android:background="@drawable/glow_blue_500" />

    <!-- ============ ОСНОВНОЙ КОНТЕНТ ============ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@android:color/transparent">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="14dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/header_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_lock"
                android:contentDescription="@string/app_name"
                app:tint="@color/color_primary" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:id="@+id/header_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ALT VPN"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/header_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="приватный"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:alpha="0.6" />
            </LinearLayout>
            <View android:layout_width="40dp" android:layout_height="40dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1A2A45"
            android:alpha="0.5" />

        <!-- Статус как на 2 фото -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Соединение не установлено"
            android:textSize="14sp"
            android:textColor="#7A8BB0"
            android:gravity="center"
            android:layout_marginTop="28dp"
            android:alpha="0.9" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingBottom="16dp">

                <!-- ======== Central Circle с LED кольцами ======== -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:layout_gravity="center">

                    <!-- Внешнее темное кольцо с обводкой -->
                    <View
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_dark_circle" />

                    <!-- Тонкое синее свечение-кольцо поверх -->
                    <View
                        android:layout_width="260dp"
                        android:layout_height="260dp"
                        android:layout_gravity="center"
                        android:background="@drawable/circle_border"
                        android:alpha="0.8" />

                    <!-- Свечение ПОД кнопкой -->
                    <View
                        android:layout_width="132dp"
                        android:layout_height="132dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_fab_glow"
                        android:alpha="0.35" />

                    <!-- Кнопка -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/fab"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_24dp"
                        android:backgroundTint="@color/color_primary"
                        app:fabCustomSize="96dp"
                        app:maxImageSize="36dp"
                        app:elevation="18dp"
                        app:borderWidth="0dp" />
                </FrameLayout>

                <!-- ======== Server Card - Glass + LED stroke ======== -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:cardBackgroundColor="#16213A"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#25407A">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="10dp"
                                android:layout_height="10dp"
                                android:background="@drawable/circle_dot"
                                android:backgroundTint="@color/color_primary" />

                            <TextView
                                android:id="@+id/server_name_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="10dp"
                                android:text="Luna VPN — Netherlands"
                                android:textColor="@color/text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="214ms"
                                android:textSize="12sp"
                                android:textColor="#7A8BB0"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/server_desc_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginStart="20dp"
                            android:alpha="0.7"
                            android:text="VLESS • защищённый туннель"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/circle_dot"
                                android:backgroundTint="#3A5CFF"
                                android:alpha="0.2"/>

                            <TextView
                                android:id="@+id/server_country_text"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginStart="-18dp"
                                android:text="Netherlands Server"
                                android:textColor="#A0B0D0"
                                android:textSize="13sp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ======== Statistic ======== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="4dp"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_chart"
                            app:tint="#6A7DA0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="СТАТИСТИКА"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:textColor="#6A7DA0" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            app:cardBackgroundColor="#16213A"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#1F335A">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingVertical="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="↓ СКАЧАТЬ"
                                    android:textSize="9sp"
                                    android:textStyle="bold"
                                    android:textColor="#6A7DA0" />

                                <TextView
                                    android:id="@+id/download_speed_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mb/s"
                                    android:textColor="#6A7DA0"
                                    android:textSize="10sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            app:cardBackgroundColor="#16213A"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#1F335A">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:paddingVertical="14dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="↑ ЗАГРУЗИТЬ"
                                    android:textSize="9sp"
                                    android:textStyle="bold"
                                    android:textColor="#6A7DA0" />

                                <TextView
                                    android:id="@+id/upload_speed_text"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.0"
                                    android:textColor="#FFFFFF"
                                    android:textSize="22sp"
                                    android:textStyle="bold"
                                    android:layout_marginTop="4dp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mb/s"
                                    android:textColor="#6A7DA0"
                                    android:textSize="10sp" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/view_all_servers_btn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="18dp"
                    android:text="Смотреть все серверы"
                    android:textSize="14sp"
                    app:cornerRadius="16dp"
                    app:icon="@drawable/ic_arrow_right"
                    app:iconGravity="end"
                    android:backgroundTint="#1C2A45"
                    android:textColor="#FFFFFF"
                    android:elevation="0dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/search_btn"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:layout_marginEnd="6dp"
                        android:text="Начать искать"
                        app:cornerRadius="14dp"
                        android:backgroundTint="#19243C"
                        android:textColor="#A0B0D0"
                        app:icon="@drawable/ic_search" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/edit_btn"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:text="Редактировать"
                        app:cornerRadius="14dp"
                        android:backgroundTint="#19243C"
                        android:textColor="#A0B0D0"
                        app:icon="@drawable/ic_edit" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_navigation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#131D32"
            app:menu="@menu/menu_alt_bottom_nav"
            app:itemTextColor="@color/bottom_nav_color"
            app:itemIconTint="@color/bottom_nav_color"
            app:elevation="0dp" />
    </LinearLayout>
</FrameLayout>
